# ─────────────────────────────────────────────────────────────────────────────
# AERP Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=aerp
POSTGRES_PASSWORD=aerp_password
POSTGRES_DB=aerp_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full DSN (auto-built from above in settings.py — don't change this)
DATABASE_URL=postgresql+asyncpg://aerp:aerp_password@postgres:5432/aerp_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── GitHub ────────────────────────────────────────────────────────────────────
# Get from: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained
# Permissions needed: Contents (read), Pull Requests (read), Issues (read)
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Jira ──────────────────────────────────────────────────────────────────────
# Your Jira Cloud domain (e.g. mycompany.atlassian.net)
JIRA_SERVER=https://your-domain.atlassian.net
# Your Jira account email
JIRA_EMAIL=your_email@example.com
# Get from: Jira → Account Settings → Security → API Tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── Google Docs ───────────────────────────────────────────────────────────────
# (Uses OAuth flow; no service account key needed)

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Set the LLM provider: 'gemini' (default), 'openai', or 'anthropic'
LLM_PROVIDER=gemini

# 1. Google Gemini (Default)
GOOGLE_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# 2. OpenAI
# Required if LLM_PROVIDER=openai (also used for embeddings if Anthropic is selected)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# 3. Anthropic
# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# 4. Ollama (Local Models)
# Required if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# ── Agent Settings ────────────────────────────────────────────────────────────
# Minimum confidence score for a finding to appear in GitHub PR comments
# Findings below this threshold only appear in the internal report
MIN_CONFIDENCE_FOR_PR_COMMENT=0.60

# Maximum tool call iterations per agent (prevents infinite loops)
AGENT_MAX_ITERATIONS=10

# Risk score threshold above which Human-in-the-Loop is triggered
HITL_RISK_THRESHOLD=40
